## Copia este archivo a `application-local.properties` (está en .gitignore)
## y arranca con: ./mvnw spring-boot:run -Dspring-boot.run.profiles=local
##
## Alternativa: exporta DB_URL, DB_USER, DB_PASS.
#
#spring.datasource.url=jdbc:postgresql://localhost:5432/banco2026
#spring.datasource.username=postgres
#spring.datasource.password=tu_password
#
# Opcional: cuando el esquema ya existe y no quieres que Hibernate recree tablas al iniciar:
#spring.jpa.hibernate.ddl-auto=update
# (o en .env: DDL_AUTO=update)
